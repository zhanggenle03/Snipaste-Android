<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="30dp"
    android:layout_height="150dp"
    android:background="@drawable/bg_opacity_slider"
    android:paddingHorizontal="5dp"
    android:paddingVertical="9dp">

    <!--
      竖向透明度滑块：原生 SeekBar 为水平，这里用 layout 尺寸 132x20 + 旋转 270°
      渲染后视觉上成为 20 宽 × 132 高的竖条（容器内部 20x132，可容纳）。
      圆角深色背景 + 圆形滑块按钮，比之前 32dp 细条更纤细。
    -->
    <SeekBar
        android:id="@+id/opacitySeekBar"
        android:layout_width="132dp"
        android:layout_height="20dp"
        android:layout_gravity="center"
        android:rotation="270"
        android:max="100"
        android:progress="100"
        android:thumb="@drawable/seek_thumb"
        android:thumbOffset="9dp"
        android:progressDrawable="@drawable/seek_track" />

</FrameLayout>
