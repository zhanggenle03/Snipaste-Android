<?xml version="1.0" encoding="utf-8"?>
<com.dd.ShadowLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/imageOutterShadow"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:sl_dx="0dp"
    app:sl_shadowColor="#33000000"
    app:sl_shadowRadius="4dp"
    android:minWidth="50dp"
    android:minHeight="50dp">
    <RelativeLayout
        android:id="@+id/imageOutter"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >
        <com.to3g.snipasteandroid.view.ScaleImage
            android:id="@+id/scaleImage"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_scaleimage"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            />

        <!-- 右上角关闭按钮：单击关闭贴图（替代原来的双击关闭） -->
        <ImageButton
            android:id="@+id/closeButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="4dp"
            android:background="@null"
            android:src="@drawable/icon_popup_close_with_bg_dark"
            android:scaleType="fitCenter"
            android:contentDescription="关闭贴图" />
    </RelativeLayout>
</com.dd.ShadowLayout>
